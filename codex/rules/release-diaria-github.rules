prefix_rule(
    pattern = ["git"],
    decision = "allow",
    justification = "La automatizacion de release necesita clonar, leer tags, commitear, etiquetar y hacer push desde el checkout temporal.",
    match = [
        "git fetch --tags origin",
        "git pull --ff-only origin main",
        "git push --atomic origin main v0.3.1",
    ],
)

prefix_rule(
    pattern = ["gh"],
    decision = "allow",
    justification = "La automatizacion de release necesita validar auth y consultar/publicar releases en GitHub.",
    match = [
        "gh auth status",
        "gh auth setup-git",
        "gh release list --repo KikoNet13/frosthaven-campaign-journal",
        "gh release create v0.3.1 --repo KikoNet13/frosthaven-campaign-journal --title v0.3.1 --notes-file .codex_tmp/v0.3.1-release-notes.md build/apk/frosthaven_campaign_journal.apk",
    ],
)

prefix_rule(
    pattern = ["pipenv"],
    decision = "allow",
    justification = "La automatizacion de release necesita ejecutar tests y construir el APK con el entorno del proyecto.",
    match = [
        "pipenv run python -m unittest discover -s tests -p test_*.py",
        "pipenv run flet build apk . --yes --no-rich-output --skip-flutter-doctor -o build/apk --build-version 0.3.1 --build-number 123",
    ],
)

prefix_rule(
    pattern = ["python"],
    decision = "allow",
    justification = "La automatizacion de release puede usar helpers puntuales en Python para preparar ficheros temporales o sintetizar notas.",
    match = [
        "python -c print('ok')",
    ],
)

# Los scripts complejos de PowerShell no siempre se descomponen en subcomandos
# para aplicar rules, asi que se permite tambien el wrapper completo.
prefix_rule(
    pattern = ["C:\\WINDOWS\\System32\\WindowsPowerShell\\v1.0\\powershell.exe", "-Command"],
    decision = "allow",
    justification = "La automatizacion de release ejecuta scripts complejos de PowerShell para tests, build APK y cleanup en Windows.",
)

prefix_rule(
    pattern = ["powershell.exe", "-Command"],
    decision = "allow",
    justification = "Alias corto del wrapper de PowerShell usado por la automatizacion de release en Windows.",
)

prefix_rule(
    pattern = ["powershell", "-Command"],
    decision = "allow",
    justification = "Alias de PowerShell permitido para la automatizacion de release.",
)

prefix_rule(
    pattern = ["powershell.exe", "-c"],
    decision = "allow",
    justification = "Alias corto con -c para la automatizacion de release en Windows.",
)

prefix_rule(
    pattern = ["powershell", "-c"],
    decision = "allow",
    justification = "Alias de PowerShell con -c permitido para la automatizacion de release.",
)

prefix_rule(
    pattern = ["powershell.exe", "-File"],
    decision = "allow",
    justification = "El fallback manual puede ejecutar scripts versionados del repo en PowerShell.",
)

prefix_rule(
    pattern = ["powershell", "-File"],
    decision = "allow",
    justification = "Alias de PowerShell permitido para ejecutar el fallback manual versionado.",
)

prefix_rule(
    pattern = ["pwsh", "-Command"],
    decision = "allow",
    justification = "Compatibilidad si la automatizacion usa PowerShell 7 como wrapper.",
)

prefix_rule(
    pattern = ["pwsh", "-c"],
    decision = "allow",
    justification = "Compatibilidad con PowerShell 7 usando -c como wrapper de la automatizacion de release.",
)
